        <localActions>
            <fullName>Get_Order_Information_179WD000000WOVR</fullName>
            <description>Autolaunched flow used as an Agentforce action. Given an order identifier (Order Number or OrderId), returns Status, Estimated Delivery Date, and the number of times delivery was delayed.</description>
            <developerName>Get_Order_Information_179WD000000WOVR</developerName>
            <invocationTarget>Get_Order_Information</invocationTarget>
            <invocationTargetType>flow</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>false</isIncludeInProgressIndicator>
            <localDeveloperName>Get_Order_Information</localDeveloperName>
            <masterLabel>Get Order Information</masterLabel>
        </localActions>
        <localActions>
            <fullName>Cancel_Order_179WD000000WOVR</fullName>
            <description>Autolaunched flow used as an Agentforce action. Calls Get Order Information, then checks eligibility (status must be Backordered). When senderRole is &apos;enduser&apos; the flow only performs the eligibility check and does NOT cancel the order; for any other sender it cancels the order (sets Status to Cancelled and clears the estimated and actual delivery dates). Returns ineligible/not-found messages otherwise.</description>
            <developerName>Cancel_Order_179WD000000WOVR</developerName>
            <invocationTarget>Cancel_Order</invocationTarget>
            <invocationTargetType>flow</invocationTargetType>
            <isConfirmationRequired>false</isConfirmationRequired>
            <isIncludeInProgressIndicator>false</isIncludeInProgressIndicator>
            <localDeveloperName>Cancel_Order</localDeveloperName>
            <mappingAttributes>
                <label>senderRole</label>
                <name>input_senderRole</name>
                <parameterName>senderRole</parameterName>
                <parameterType>input</parameterType>
            </mappingAttributes>
            <masterLabel>Cancel Order</masterLabel>
        </localActions>
